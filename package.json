{
	"name": "@zendrex/annotate",
	"version": "1.0.1",
	"description": "A modern decorator and metadata system for TypeScript with built-in reflection.",
	"author": "zendrex",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./shim": {
			"import": {
				"types": "./dist/shim.d.mts",
				"default": "./dist/shim.mjs"
			},
			"require": {
				"types": "./dist/shim.d.cts",
				"default": "./dist/shim.cjs"
			}
		}
	},
	"sideEffects": [
		"./dist/shim.mjs",
		"./dist/shim.cjs"
	],
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"test": "bun test",
		"test:unit": "bun test tests/unit",
		"test:integration": "bun test tests/integration",
		"build": "tsdown",
		"check": "bunx ultracite check",
		"check:dist-helpers": "bun scripts/check-helper-imports.ts",
		"fix": "bunx ultracite fix",
		"check-types": "tsc -b",
		"changeset": "changeset",
		"version": "changeset version",
		"prepare": "lefthook install",
		"clean": "git clean -xdf dist node_modules"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.31.0",
		"@swc/core": "^1.15.30",
		"@types/bun": "^1.3.13",
		"bun-types": "^1.3.13",
		"lefthook": "^2.1.6",
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3",
		"ultracite": "^7.6.1"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Zendrex/annotate.git"
	},
	"bugs": {
		"url": "https://github.com/Zendrex/annotate/issues"
	},
	"homepage": "https://github.com/Zendrex/annotate#readme",
	"keywords": [
		"typescript",
		"decorators",
		"metadata",
		"reflection",
		"annotation",
		"interceptor"
	]
}
